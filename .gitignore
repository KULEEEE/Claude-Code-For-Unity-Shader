# Node.js
node_modules/
npm-debug.log*

# Keep the runtime node_modules that ship inside the Unity package's Server~ folder.
# Server.src~/node_modules/ stays ignored — it's only the build-time toolchain.
!unity-package/Server~/node_modules/
!unity-package/Server~/node_modules/**

# TypeScript build output for the bundled headless runner
unity-package/Server.src~/build/

# OS files
.DS_Store
Thumbs.db
Desktop.ini
nul

# IDE
.vs/
.vscode/
.idea/
*.suo
*.user
*.sln.docstates

# Claude Code local settings
.claude/
CLAUDE.md

# AI session files
.hypeai-sessions.json

# npm pack output
*.tgz

# Unity generated (not needed for this repo)
Library/
Temp/
obj/
Logs/
UserSettings/
*.csproj
*.sln
