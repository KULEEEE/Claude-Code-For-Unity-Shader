{
  "name": "unity-error-solver-mcp",
  "version": "0.5.0",
  "description": "MCP server for Unity error solving - captures Unity errors and provides AI-powered auto-fix via Claude Code",
  "type": "module",
  "main": "dist/server.mjs",
  "bin": {
    "unity-error-solver-mcp": "dist/server.mjs"
  },
  "files": [
    "dist/server.mjs"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "node esbuild.config.mjs",
    "watch": "tsc --watch",
    "start": "node dist/server.mjs",
    "prepublishOnly": "npm run build && npm run bundle"
  },
  "keywords": [
    "mcp",
    "unity",
    "error-solver",
    "debug",
    "model-context-protocol",
    "game-dev",
    "claude",
    "auto-fix"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KULEEEE/Claude-Code-For-Unity-Shader.git"
  },
  "homepage": "https://github.com/KULEEEE/Claude-Code-For-Unity-Shader#readme",
  "bugs": {
    "url": "https://github.com/KULEEEE/Claude-Code-For-Unity-Shader/issues"
  },
  "license": "MIT",
  "author": "KULEEEE",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.3"
  }
}
